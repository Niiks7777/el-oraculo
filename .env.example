# ═══════════════════════════════════════════════
# El Oraculo — Configuration
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

NODE_ENV=production

# ─── Your Trading Bot ─────────────────────────
# URL of your trading bot's REST API
EL_PESOS_API=http://localhost:4201

# Path to your bot's SQLite database (read-only access)
# Leave empty or remove if your bot doesn't use SQLite
TRADING_DB_PATH=./data/trading.db

# ─── Relay Server ─────────────────────────────
RELAY_API=http://localhost:4202

# Path to your trading bot's .env file (for Binance API keys)
# The relay reads this to proxy read-only Binance API calls
TRADING_BOT_ENV_PATH=/path/to/your-bot/.env

# ─── Oraculo Dashboard ───────────────────────
ORACULO_PORT=4203

# ─── Infrastructure (optional) ───────────────
OLLAMA_URL=http://localhost:11434
PGVECTOR_URL=postgresql://user:password@localhost:5432/oraculo

# ─── OpenRouter — Pro Feature (free LLM predictions) ─────
# Get a free key at https://openrouter.ai
OPENROUTER_API_KEY=
OPENROUTER_DAILY_CAP=5

# ─── Telegram Alerts (optional) ──────────────
# Create a bot at https://t.me/BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
